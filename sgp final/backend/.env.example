# Database configuration
# Leave DATABASE_URL unset to use the default SQLite file at backend/local.db
# DATABASE_URL=sqlite:///C:/path/to/sgp-final/backend/local.db
# DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/sgp

# Optional SQLAlchemy SQL logging
DATABASE_ECHO=false

# Admin registration secret (required when role=Admin during signup)
ADMIN_REGISTRATION_KEY=charusatsgp

# Firebase cloud persistence (Firestore + Storage)
# Use either JSON path OR JSON content string.
FIREBASE_SERVICE_ACCOUNT_JSON=C:/path/to/firebase-service-account.json
# FIREBASE_SERVICE_ACCOUNT_JSON_CONTENT={"type":"service_account",...}
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_STORAGE_BUCKET=your-firebase-project-id.appspot.com
FIREBASE_RESTORE_ON_STARTUP=true
FIREBASE_STORAGE_MAKE_PUBLIC=false
